{
  "name": "humans.md",
  "version": "0.1.0",
  "description": "CLI to setup configurations to enforce HUMANS.md file in your project",
  "keywords": [
    "agents",
    "ai",
    "antigravity",
    "claude",
    "codex",
    "config",
    "cursor",
    "deny",
    "gemini",
    "humans-md",
    "humansmd",
    "opencode",
    "permissions",
    "zed"
  ],
  "license": "Apache-2.0",
  "author": "4rcadia",
  "bin": {
    "humansmd": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:write": "oxfmt --write",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "js-yaml": "^5.1.0",
    "jsonc-parser": "^3.3.1",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
